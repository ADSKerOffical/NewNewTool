player = player or game.Players.LocalPlayer
local tool = Instance.new("Tool", player:WaitForChild("Backpack"))
tool.Name = "Almighty Slap"
tool.RequiresHandle = false
tool:SetAttribute("Tool_Type", "Melee")
tool:SetAttribute("Tool_Rare", "Divine")
tool:SetAttribute("Tool_Craft", "Slap, Amplifier, Particle Accelerator, RGB, Uranus")

player.Character:WaitForChild("Humanoid").MaxHealth += 1000
player.Character.Humanoid.Health += 1000

local ambient = Instance.new("Sound")
ambient.SoundId = "rbxassetid://125421681778301"
ambient.Looped = true
ambient.Volume = 1.5
ambient.Playing = false

local lastPressTime = 0
tool.Activated:Connect(function()
  local currentTime = tick()
            if currentTime - lastPressTime >= 1.5 then
                lastPressTime = currentTime 
local owner = tool.Parent
local Anim = Instance.new("Animation")
Anim.AnimationId = "rbxassetid://243827693"
game.Debris:AddItem(Anim, 3)

local k = owner.Humanoid:LoadAnimation(Anim)
k:Play()
k:AdjustSpeed(1)
   task.wait(0.35)
local humanoids = {}
for _, part in next, workspace:GetPartBoundsInRadius(owner.HumanoidRootPart.Position, 50) do
    if part.Parent:IsA("Model") and part.Parent:FindFirstChildOfClass("Humanoid") and not part:IsDescendantOf(owner) then
      if not table.find(humanoids, part.Parent:FindFirstChildOfClass("Humanoid")) then
        table.insert(humanoids, part.Parent:FindFirstChildOfClass("Humanoid"))
      end
    end
  end

for _, humanoid in next, humanoids do
   humanoid:TakeDamage(250)
   humanoid.Sit = true
   humanoid.RootPart.AssemblyLinearVelocity += (owner.HumanoidRootPart.Position - humanoid.RootPart.Position).Unit * -300 + Vector3.new(0, 100, 0)
   
   local sound = Instance.new("Sound", humanoid.RootPart)
   sound.SoundId = "rbxassetid://125416415243592"
   sound.Volume = 1
   sound.PlaybackSpeed = 1
   sound.Looped = false
   sound:Play()
   game.Debris:AddItem(sound, 5)
end

local shock = Instance.new("Part", workspace)
shock.Anchored = true
shock.CanCollide = false
shock.CanTouch = false
shock.Position = owner.HumanoidRootPart.Position
shock.Color = Color3.new(0, 0, 0)
game.Debris:AddItem(shock, 3)

local shockmesh = Instance.new("SpecialMesh", shock)
shockmesh.MeshId = "rbxassetid://73432515253008"
shockmesh.Scale = Vector3.new(1, 1, 1)

game:GetService("TweenService"):Create(shockmesh, TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, 0, false, 0), {
   Scale = Vector3.new(50, 1.5, 50)
}):Play()

game:GetService("TweenService"):Create(shock, TweenInfo.new(1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, 0, false, 0), {
     Transparency = 1
}):Play()

task.spawn(function()
   repeat game:GetService("RunService").Heartbeat:Wait()
      shock.Color = Color3.fromHSV(tick() % 5 / 5, 1, 1)
   until not shock or shock == nil
end)

local pos = owner.HumanoidRootPart.CFrame
for i = 1, 3 do task.wait(0.075)
   local colors = {Color3.new(1, 0, 0), Color3.new(1, 0.5, 0), Color3.new(1, 1, 0), Color3.new(0, 1, 0), Color3.new(0, 1, 1), Color3.new(0, 0, 1), Color3.new(0.5, 0, 0.5)}
   local explosion = Instance.new("Part", workspace)
   explosion.CFrame = pos * CFrame.new(0, 0, -(25 * i))
   explosion.Size = Vector3.new(15 + i^2, 15 + i^2, 15 + i^2)
   explosion.CanCollide = false
   explosion.Shape = "Ball"
   explosion.Anchored = true
   explosion.Material = "Neon"
   explosion.Color = colors[math.random(1, #colors)]
   game.Debris:AddItem(explosion, 3)
   
   local humanoids = {}
for _, part in next, workspace:GetPartBoundsInRadius(explosion.Position, 20) do
    if part.Parent:IsA("Model") and part.Parent:FindFirstChildOfClass("Humanoid") and not part:IsDescendantOf(owner) then
      if not table.find(humanoids, part.Parent:FindFirstChildOfClass("Humanoid")) then
        table.insert(humanoids, part.Parent:FindFirstChildOfClass("Humanoid"))
      end
    end
  end

   for _, humanoid in next, humanoids do
      humanoid:TakeDamage(120 + (explosion.Size.X + explosion.Size.Y + explosion.Size.Z))
      humanoid.Sit = true
      humanoid.RootPart.AssemblyLinearVelocity += (explosion.Position - humanoid.RootPart.Position).Unit * -200
   end
   
   local sound = Instance.new("Sound", explosion)
   sound.SoundId = "rbxassetid://137879562458883"
   sound:Play()
   
   task.delay(0.75, function()
      game:GetService("TweenService"):Create(explosion, TweenInfo.new(0.5, Enum.EasingStyle.Sine, Enum.EasingDirection.Out, 0, false, 0), {
        Transparency = 1,
        Color = Color3.new(0, 0, 0)
      }):Play()
   end)
end
   end
end)

tool.Equipped:Connect(function()
   local owner = tool.Parent
   task.spawn(function()
      ambient.Parent = owner.HumanoidRootPart
      ambient.Playing = true
      owner.Humanoid.WalkSpeed = 75
      owner.Humanoid.JumpPower = 100
      
      local core = Instance.new("Part", owner.HumanoidRootPart)
      core.Name = "CORE"
      core.CanCollide = false
      core.CanQuery = false
      core.CanTouch = false
      core.Transparency = 1
      core.Size = Vector3.zero
      
      local weld = Instance.new("Weld", core)
      weld.Part0 = core
      weld.Part1 = owner.HumanoidRootPart
      
      local shield = Instance.new("Part", core)
      shield.Massless = true
      shield.CanCollide = false
      shield.Shape = "Ball"
      shield.Size = Vector3.new(50, 50, 50)
      shield.Material = "ForceField"
      
      shield.Touched:Connect(function(part)
         if part.Parent:IsA("Model") and part.Parent:FindFirstChildOfClass("Humanoid") and not part.Parent:IsDescendantOf(owner) then
            local humanoid = part.Parent:FindFirstChildOfClass("Humanoid")
            humanoid:TakeDamage(0.5)
            humanoid.RootPart.AssemblyLinearVelocity += (shield.Position - humanoid.RootPart.Position).Unit * -50
         end
      end)
      
      local weld2 = Instance.new("Weld", shield)
      weld2.Part0 = shield
      weld2.Part1 = core
      
      local effect = Instance.new("ParticleEmitter", core)
      effect.Texture = "https://www.roblox.com/asset-thumbnail/image?assetId=117166078&width=432&height=432&format=png"
      effect.Size = NumberSequence.new(7.5, 7.5)
      effect.Lifetime = NumberRange.new(1, 1)
      effect.Rate = 2
      effect.ZOffset = -1
      effect.LockedToPart = true
      effect.RotSpeed = NumberRange.new(-360, 360)
      effect.Speed = NumberRange.new(0, 0)
      effect.SpreadAngle = Vector2.new(-360, 360)
      effect.Color = ColorSequence.new(Color3.fromHSV(tick() % 5 / 5, 1, 1))
      
      task.spawn(function()
        local i = 0
        repeat game:GetService("RunService").Heartbeat:Wait()
           i = (i + game:GetService("RunService").Heartbeat:Wait() * 1) % 1
           shield.Color = Color3.fromHSV(i, 1, 1)
           effect.Color = ColorSequence.new(Color3.fromHSV(tick() % 5 / 5, 1, 1))
        until not shield or shield.Parent == nil
      end)
        tool.Unequipped:Wait()
      ambient.Playing = false
      owner.Humanoid.WalkSpeed = 16
      owner.Humanoid.JumpPower = 50
      core:Destroy()
   end)
end)
