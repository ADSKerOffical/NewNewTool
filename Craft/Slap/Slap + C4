player = player or game.Players.LocalPlayer
local tool = Instance.new("Tool", player:WaitForChild("Backpack"))
tool.Name = "Explosive Slap"
tool.RequiresHandle = false
tool:SetAttribute("Tool_Type", "Melee")
tool:SetAttribute("Tool_Rare", "Rare")
tool:SetAttribute("Tool_Craft", "Slap, C4")

local lastPressTime = 0
tool.Activated:Connect(function()
  local currentTime = tick()
            if currentTime - lastPressTime >= 3 then
                lastPressTime = currentTime 
local owner = tool.Parent
local Anim = Instance.new("Animation")
Anim.AnimationId = "rbxassetid://243827693"
game.Debris:AddItem(Anim, 3)

local k = owner.Humanoid:LoadAnimation(Anim)
k:Play()
k:AdjustSpeed(1)
   task.wait(.35)
local explosion = Instance.new("Explosion")
explosion.BlastRadius = 30
explosion.ExplosionType = Enum.ExplosionType.Craters
explosion.DestroyJointRadiusPercent = 0
explosion.Position = owner.HumanoidRootPart.Position + owner.HumanoidRootPart.CFrame.LookVector * 6
explosion.Parent = workspace
game.Debris:AddItem(explosion, 5)

local sound = Instance.new("Sound", owner.HumanoidRootPart)
sound.SoundId = "rbxassetid://5801257793"
sound.Volume = 3
sound.PlaybackSpeed = 1
sound.Looped = false
sound:Play()
game.Debris:AddItem(sound, 5)

local humanoids = {}
for _, part in next, workspace:GetPartBoundsInRadius(owner.HumanoidRootPart.Position, 20) do
    if part.Parent:IsA("Model") and part.Parent:FindFirstChildOfClass("Humanoid") and not part:IsDescendantOf(owner) then
      if not table.find(humanoids, part.Parent:FindFirstChildOfClass("Humanoid")) then
        table.insert(humanoids, part.Parent:FindFirstChildOfClass("Humanoid"))
      end
    end
  end

for _, humanoid in next, humanoids do
   humanoid:TakeDamage(50)
   humanoid.Sit = true
   humanoid.RootPart.AssemblyLinearVelocity += owner.HumanoidRootPart.CFrame.LookVector * 150
end
   end
end)
