player = player or game.Players.LocalPlayer
local tool = Instance.new("Tool", player:WaitForChild("Backpack"))
tool.Name = "Metal Slap"
tool.ToolTip = "Cyborg Strike"
tool.RequiresHandle = false
tool:SetAttribute("Tool_Type", "Melee")
tool:SetAttribute("Tool_Rare", "Super Rare")
tool:SetAttribute("Tool_Craft", "Slap, Metal")

local lastPressTime = 0
tool.Activated:Connect(function()
  local currentTime = tick()
            if currentTime - lastPressTime >= 0.75 then
                lastPressTime = currentTime 
local owner = tool.Parent
local Anim = Instance.new("Animation")
Anim.AnimationId = "rbxassetid://243827693"
game.Debris:AddItem(Anim, 3)

local k = owner.Humanoid:LoadAnimation(Anim)
k:Play()
k:AdjustSpeed(2)
  task.wait(0.15)
local sound = Instance.new("Sound", owner.HumanoidRootPart)
sound.SoundId = "rbxassetid://5835032207"
sound.Volume = 1
sound.PlaybackSpeed = 1
sound:Play()
game.Debris:AddItem(sound, 6)
  
local humanoids = {}
for _, part in next, workspace:GetPartBoundsInRadius(owner.HumanoidRootPart.Position, 6) do
    if part.Parent:IsA("Model") and part.Parent:FindFirstChildOfClass("Humanoid") and not part:IsDescendantOf(owner) then
      if not table.find(humanoids, part.Parent:FindFirstChildOfClass("Humanoid")) then
        table.insert(humanoids, part.Parent:FindFirstChildOfClass("Humanoid"))
      end
    end
  end

for _, humanoid in next, humanoids do
  humanoid:TakeDamage(20 + (owner.Humanoid.FloorMaterial == Enum.Material.Air and 20 or 0))
  humanoid.Sit = true
  humanoid.RootPart.Velocity = owner.HumanoidRootPart.CFrame.LookVector * 200 + Vector3.new(0, (owner.Humanoid.FloorMaterial == Enum.Material.Air and -100 or 50), 0)
local sound = Instance.new("Sound", humanoid.RootPart)
sound.SoundId = "rbxassetid://4766119678"
sound.Volume = 1
sound.PlaybackSpeed = 1
sound.Looped = false
sound:Play()
game.Debris:AddItem(sound, 6)
end
            end
end)

tool.Equipped:Connect(function()
  local owner = tool.Parent
  for _, side in next, Enum.NormalId:GetEnumItems() do
    task.spawn(function()
      local decal = Instance.new("Decal", owner:FindFirstChild("Right Arm"))
      decal.Texture = "rbxassetid://16412011809"
      decal.Face = side
       tool.Unequipped:Wait()
      decal:Destroy()
    end)
  end
end)
